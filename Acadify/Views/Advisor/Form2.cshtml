@using Acadify.Models
@model Acadify.Models.Form2ViewModel

@{
    Layout = "_AdvisorLayout";
    ViewData["Title"] = "Form 2";

    var advisorNotes = ViewBag.AdvisorNotes as string ?? "";

    string ToEnglishNumbers(object? value)
    {
        if (value == null)
            return "";

        return value.ToString()!
            .Replace("٠", "0")
            .Replace("١", "1")
            .Replace("٢", "2")
            .Replace("٣", "3")
            .Replace("٤", "4")
            .Replace("٥", "5")
            .Replace("٦", "6")
            .Replace("٧", "7")
            .Replace("٨", "8")
            .Replace("٩", "9");
    }
}

<link rel="stylesheet" href="~/css/advisorform2.css" asp-append-version="true" />

<main class="cr-page">
    <section class="cr-shell">

        <div class="cr-header">
            <div class="cr-header-left">
                <span class="cr-header-icon">
                    <i class="fa-solid fa-file-lines"></i>
                </span>

                <h2 class="cr-title">Course Choice and Monitoring (Form 2)</h2>
            </div>

            <div class="cr-header-actions">
                <a class="cr-btn cr-small-btn"
                       asp-controller="FormHistory"
                       asp-action="FormHistory"
                       asp-route-studentId="@Model.StudentId"
                       asp-route-formType="Form2">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    History
                </a>

                <button type="button" class="cr-btn cr-small-btn" onclick="window.print()">
                    Print
                    <i class="fa-solid fa-print"></i>
                </button>
            </div>
        </div>

        <div class="cr-paper">

            <h2 class="cr-form-heading">FORM-2 (Course Choice and Monitoring)</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="cr-message cr-success">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="cr-message cr-error">
                    @TempData["ErrorMessage"]
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="StudentId" />

                <div class="cr-student-line">
                    <div>
                        <strong>Student Name:</strong>
                        <span>@Model.StudentName</span>
                    </div>

                    <div>
                        <strong>Student ID:</strong>
                        <span>@ToEnglishNumbers(Model.StudentId)</span>
                    </div>
                </div>

                <h3 class="cr-manual-title">Student Information</h3>

                <div class="cr-table-wrap">
                    <table class="cr-table">
                        <tbody>
                            <tr>
                                <td>Name</td>
                                <td>
                                    <input asp-for="StudentName"
                                           class="cr-manual-input"
                                           readonly />
                                </td>

                                <td>Student ID</td>
                                <td>
                                    <input asp-for="StudentId"
                                           value="@ToEnglishNumbers(Model.StudentId)"
                                           class="cr-manual-input english-number"
                                           readonly />
                                </td>
                            </tr>

                            <tr>
                                <td>Semester</td>
                                <td>
                                    <input asp-for="Semester"
                                           class="cr-manual-input"
                                           readonly />
                                </td>

                                <td>Running Credit Hours</td>
                                <td>
                                    <input asp-for="RunningCreditHours"
                                           value="@ToEnglishNumbers(Model.RunningCreditHours)"
                                           class="cr-manual-input english-number"
                                           readonly />
                                </td>
                            </tr>

                            <tr>
                                <td>Drop Subjects</td>
                                <td>
                                    <input asp-for="DropSubjects"
                                           class="cr-manual-input"
                                           readonly />
                                </td>

                                <td>IC Subjects</td>
                                <td>
                                    <input asp-for="ICSubjects"
                                           class="cr-manual-input"
                                           readonly />
                                </td>
                            </tr>

                            <tr>
                                <td>IP Subjects</td>
                                <td colspan="3">
                                    <input asp-for="IPSubjects"
                                           class="cr-manual-input"
                                           readonly />
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="cr-manual-title">Course Recommendation for Coming Semester</h3>

                <div class="cr-table-wrap">
                    <table class="cr-table">
                        <tbody>
                            <tr>
                                <td>Advised Credit Hours</td>
                                <td>
                                    <input asp-for="AdvisedCreditHours"
                                           value="@ToEnglishNumbers(Model.AdvisedCreditHours)"
                                           class="cr-manual-input english-number"
                                           readonly />
                                </td>

                                <td>Coming Semester</td>
                                <td>
                                    <input asp-for="ComingSemester"
                                           class="cr-manual-input"
                                           readonly />
                                </td>
                            </tr>

                            <tr>
                                <td>Level</td>
                                <td colspan="3">
                                    <input asp-for="Level"
                                           class="cr-manual-input"
                                           readonly />
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <h3 class="cr-manual-title">Selected Courses</h3>

                <div class="cr-table-wrap">
                    <table class="cr-table cr-selected-table">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Credit Hours</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.SelectedCourses != null && Model.SelectedCourses.Any())
                            {
                                for (int i = 0; i < Model.SelectedCourses.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            @Model.SelectedCourses[i].CourseId
                                            <input type="hidden"
                                                   name="SelectedCourses[@i].CourseId"
                                                   value="@Model.SelectedCourses[i].CourseId" />
                                        </td>

                                        <td>
                                            @ToEnglishNumbers(Model.SelectedCourses[i].Hours)
                                            <input type="hidden"
                                                   name="SelectedCourses[@i].Hours"
                                                   value="@Model.SelectedCourses[i].Hours" />
                                        </td>
                                    </tr>
                                }

                                <tr class="cr-total-row">
                                    <td>Total</td>
                                    <td>@ToEnglishNumbers(Model.SelectedCourses.Sum(x => x.Hours))</td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2">No selected courses</td>
                                </tr>

                                <tr class="cr-total-row">
                                    <td>Total</td>
                                    <td>0</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h3 class="cr-manual-title">Advisor Notes</h3>

                <div class="cr-manual-wrap">
                    <textarea name="AdvisorNotes"
                              class="cr-manual-input"
                              rows="5"
                              placeholder="Write advisor notes here...">@advisorNotes</textarea>
                </div>

                <div class="cr-btn-wrap">
                    <button type="submit"
                            asp-controller="Advisor"
                            asp-action="SaveForm2"
                            class="cr-btn">
                        Save
                    </button>

                    <button type="submit"
                            asp-controller="Advisor"
                            asp-action="SendForm2"
                            class="cr-btn">
                        Send To The Advising Committee
                    </button>

                    <button type="submit"
                            asp-controller="Advisor"
                            asp-action="ReturnForm2ToStudent"
                            class="cr-btn">
                        Return To Student
                    </button>
                </div>
            </form>
        </div>

    </section>


</main>


@functions {
    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "U";

        var cleanName = name
            .Replace("(me)", "", StringComparison.OrdinalIgnoreCase)
            .Replace("Dr.", "", StringComparison.OrdinalIgnoreCase)
            .Replace("Dr", "", StringComparison.OrdinalIgnoreCase)
            .Trim();

        var parts = cleanName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .ToList();

        if (parts.Count == 0)
            return "U";

        if (parts.Count == 1)
            return parts[0].Substring(0, 1).ToUpper();

        return (parts.First().Substring(0, 1) + parts.Last().Substring(0, 1)).ToUpper();
    }
}
@model Acadify.Models.CommunityAdvisorVM

@{
    Layout = "_AdvisorLayout";
    ViewData["Title"] = "Community Advisor";
    var index = 0;

    var currentUserName = ViewBag.CurrentUserName as string ?? "Advisor";
    var currentUserInitials = GetInitials(currentUserName);
}

<div class="community-advisor-page">

    <div class="community-left">
        <h2 class="community-title">Community</h2>
        <div class="community-subtitle">Today</div>

        <div class="messages-area">
            @foreach (var msg in Model.Messages)
            {
                index++;

                var rowClass = msg.IsAdvisorMessage ? "right" : "left";

                var circleClass = "circle-blue";
                var nameClass = "name-blue";
                var bubbleClass = msg.BubbleColorClass;

                if (msg.BubbleColorClass == "msg-pink")
                {
                    circleClass = "circle-pink";
                    nameClass = "name-pink";
                }
                else if (msg.BubbleColorClass == "msg-purple")
                {
                    circleClass = "circle-purple";
                    nameClass = "name-purple";
                }
                else if (msg.BubbleColorClass == "msg-indigo")
                {
                    circleClass = "circle-indigo";
                    nameClass = "name-indigo";
                }

                if (index == 2)
                {
                    bubbleClass += " msg-wide";
                }

                <div class="message-row @rowClass row-@index">
                    @if (!msg.IsAdvisorMessage)
                    {
                        <div class="initial-circle @circleClass">@GetInitials(msg.SenderName)</div>
                    }

                    <div class="message-box @bubbleClass">
                        <div class="sender-name @nameClass">@msg.SenderName</div>
                        <div class="message-text">@msg.MessageText</div>
                    </div>

                    @if (msg.IsAdvisorMessage)
                    {
                        <div class="initial-circle @circleClass">@GetInitials(msg.SenderName)</div>
                    }
                </div>
            }
        </div>

        <div id="liveMessages" class="live-messages"></div>

        <div class="chat-section">
            <div class="typing-indicator">
                <div class="typing-user">@currentUserInitials</div>                <div class="dots">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>

            <div class="chat-input-box">
    <input type="text" id="chatMessageInput" class="chat-text-input" placeholder="Type here..." />

    <button type="button" class="chat-send-btn" id="sendBtn">
        Send
    </button>
</div>
        </div>
    </div>

    <div class="community-right">
        <h3 class="members-title">Members</h3>

        <div class="members-list">
            @foreach (var member in Model.Members)
            {
                <div class="member-card">
                    <img src="@Url.Content(member.ImagePath)" alt="member" class="member-avatar" />
                    <p class="member-name">@member.Name</p>
                </div>
            }
        </div>
    </div>

</div>
<script>
    const input = document.getElementById("chatMessageInput");
    const sendBtn = document.getElementById("sendBtn");
    const liveMessages = document.getElementById("liveMessages");
    

    function getInitials(name) {
        if (!name) return "U";

        const cleanName = name
            .replace("(me)", "")
            .replace("Dr.", "")
            .replace("Dr", "")
            .trim();

        const parts = cleanName.split(/\s+/).filter(Boolean);

        if (parts.length === 0) return "U";
        if (parts.length === 1) return parts[0].charAt(0).toUpperCase();

        return (parts[0].charAt(0) + parts[parts.length - 1].charAt(0)).toUpperCase();
    }

    function escapeHtml(value) {
        return value
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    async function sendMessage() {
        const text = input.value.trim();
        if (text === "") return;

        try {
            const response = await fetch('/Advisor/SendAdvisorMessage', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ message: text })
            });

            if (!response.ok) {
                throw new Error("Failed to send message.");
            }

            const data = await response.json();

            if (!data.success) {
                return;
            }

            const senderName = data.senderName || "Advisor";
            const senderInitials = getInitials(senderName);

            const row = document.createElement("div");
            row.className = "message-row right live-row";

            row.innerHTML = `
                <div class="message-box msg-purple live-bubble">
                    <div class="sender-name name-purple">${escapeHtml(senderName)} (me)</div>
                    <div class="message-text">${escapeHtml(data.text)}</div>
                </div>
                <div class="initial-circle circle-purple">${senderInitials}</div>
            `;

            liveMessages.prepend(row);
            input.value = "";
            input.focus();
        } catch (error) {
            console.error(error);
            alert("Something went wrong while sending the message.");
        }
    }

    sendBtn.addEventListener("click", sendMessage);

    input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
            e.preventDefault();
            sendMessage();
        }
    });

    
</script>
@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Student") - Acadify</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/RahafZh.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/StudentLayout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/StudentForm2.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/UploadTranscript.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/StudentChat.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>

<body class="main-layout @ViewBag.BodyClass">

    <div class="student-layout">

        @{
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

            var studentName = ViewBag.StudentName as string
                ?? Context.Session.GetString("UserName")
                ?? "Student";

            var studentEmail = ViewBag.StudentEmail as string
                ?? Context.Session.GetString("UserEmail")
                ?? "";
        }

        <!-- Sidebar -->
        <aside class="student-sidebar">

            <!-- Profile -->
            <div class="student-profile">
                <div class="profile-top">
                    <img src="~/images/user.png" class="student-avatar" alt="Student" />

                    <button type="button" class="topbar-notif-btn" onclick="toggleNotifications()">
                        <i class="fa-regular fa-bell"></i>
                    </button>
                </div>

                <h4>@studentName</h4>

                @if (!string.IsNullOrWhiteSpace(studentEmail))
                {
                    <p>@studentEmail</p>
                }
            </div>

            <!-- Menu -->
            <ul class="student-menu">
                <li class="@(currentAction == "StudentHome" ? "active" : "")">
                    <a asp-controller="Student" asp-action="StudentHome">
                        <i class="fa-solid fa-house"></i>
                        <span>Homepage</span>
                    </a>
                </li>

                <li class="@(currentAction == "CommunityStudent" ? "active" : "")">
                    <a asp-controller="Student" asp-action="CommunityStudent">
                        <i class="fa-solid fa-users"></i>
                        <span>Community</span>
                    </a>
                </li>

                <li class="@(currentAction == "Chat" ? "active" : "")">
                    <a asp-controller="Student" asp-action="Chat">
                        <i class="fa-solid fa-calendar-check"></i>
                        <span>Meeting</span>
                    </a>
                </li>
                <li class="@(ViewData["Title"]?.ToString() == "Course Recommendation" ? "active" : "")">
                    <a asp-controller="Student" asp-action="CourseRecommendation">
                        <i class="fa-solid fa-book"></i>
                        <span>Course Recommendation</span>
                    </a>
                </li>
            </ul>

            <!-- Logout -->
            <div class="logout">
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="background:none;border:none;color:inherit;display:flex;align-items:center;gap:10px;cursor:pointer;font:inherit;padding:0;">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </div>

        </aside>

        <!-- Main Content -->
        <div class="main-background-box">
            <div class="page-content">
                @RenderBody()
            </div>
        </div>

    </div>

    @await Component.InvokeAsync("Notifications")

    <script>
        function toggleNotifications() {
            const overlay = document.getElementById('notifOverlay');
            if (!overlay) return;
            overlay.classList.toggle('show');
        }

        function closeNotifications(e) {
            if (e) e.preventDefault();
            const overlay = document.getElementById('notifOverlay');
            if (!overlay) return;
            overlay.classList.remove('show');
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>

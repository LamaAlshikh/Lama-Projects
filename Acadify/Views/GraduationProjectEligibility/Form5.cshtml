@model Acadify.ViewModels.GraduationProjectEligibilityFormVM

@{
    Layout = "_AdvisorLayout";
    ViewData["Title"] = "Graduation Project Eligibility";

    bool transcriptMissing = ViewBag.TranscriptMissing == true;
}

<link rel="stylesheet" href="~/css/site.css" />
<link rel="stylesheet" href="~/css/form5.css" />

<div class="form5-container">

    @if (TempData["ActionMessage"] != null)
    {
        <div class="form-alert-success">
            @TempData["ActionMessage"]
        </div>
    }

    <div class="form5-header">
        <div class="form5-title">
            <i class="fa-solid fa-file-lines"></i>
            <h2>Graduation Project Eligibility (Form 5)</h2>
        </div>

        @if (!Model.IsHistoryView && !transcriptMissing)
        {
            <div class="form5-header-actions">
                <a class="btn-history"
                       asp-controller="FormHistory"
                       asp-action="FormHistory"
                       asp-route-studentId="@Model.Form.StudentId"
                       asp-route-formType="GraduationProjectEligibilityForm">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    History
                </a>

                <button type="button" class="print-btn" onclick="window.print()">
                    <i class="fa-solid fa-print"></i>
                    Print
                </button>
            </div>
        }
    </div>

    @if (transcriptMissing)
    {
        <div class="form5-section">
            <h4 style="text-align:center; margin-top:80px; margin-bottom:80px;">
                The student has not uploaded the transcript yet.
            </h4>
        </div>
    }
    else
    {
        @if (!Model.IsHistoryView)
        {
            <form method="post" asp-controller="GraduationProjectEligibility" asp-action="SaveUpdate" id="form5AutoUpdateForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="FormId" />

                <div class="form5-section">
                    <div class="form5-info">
                        <p><strong>Student Name:</strong> @Model.StudentName</p>
                        <p><strong>Student ID:</strong> @Model.StudentId</p>
                    </div>

                    <h4>The Student Has Completed The Following Courses:</h4>

                    <ul class="course-list">
                        <li class="course-item">
                            <span>CPIS 351 – Analysis &amp; Design II</span>
                            <input type="checkbox" asp-for="CPIS351" onchange="this.form.submit();" />
                        </li>

                        <li class="course-item">
                            <span>CPIS 358 – Internet Application &amp; Web Programming</span>
                            <input type="checkbox" asp-for="CPIS358" onchange="this.form.submit();" />
                        </li>

                        <li class="course-item">
                            <span>CPIS 323 – Summer Training</span>
                            <input type="checkbox" asp-for="CPIS323" onchange="this.form.submit();" />
                        </li>
                    </ul>
                </div>

                <div class="form5-section">
                    <h4>The Student Has Completed or Registered For The Following Courses:</h4>

                    <ul class="course-list">
                        <li class="course-item">
                            <span>CPIS 380 – Introduction to E-Business Systems</span>
                            <input type="checkbox" asp-for="CPIS380" onchange="this.form.submit();" />
                        </li>

                        <li class="course-item">
                            <span>CPIS 357 – Software Quality &amp; Testing</span>
                            <input type="checkbox" asp-for="CPIS357" onchange="this.form.submit();" />
                        </li>

                        <li class="course-item">
                            <span>CPIS 342 – Data Mining &amp; Warehousing</span>
                            <input type="checkbox" asp-for="CPIS342" onchange="this.form.submit();" />
                        </li>
                    </ul>
                </div>
            </form>
        }
        else
        {
            <div class="form5-section">
                <div class="form5-info">
                    <p><strong>Student Name:</strong> @Model.StudentName</p>
                    <p><strong>Student ID:</strong> @Model.StudentId</p>
                </div>

                <h4>The Student Has Completed The Following Courses:</h4>

                <ul class="course-list">
                    <li class="course-item">
                        <span>CPIS 351 – Analysis &amp; Design II</span>
                        <i class="fa-solid @(Model.CPIS351 ? "fa-check completed" : "fa-xmark not-completed")"></i>
                    </li>

                    <li class="course-item">
                        <span>CPIS 358 – Internet Application &amp; Web Programming</span>
                        <i class="fa-solid @(Model.CPIS358 ? "fa-check completed" : "fa-xmark not-completed")"></i>
                    </li>

                    <li class="course-item">
                        <span>CPIS 323 – Summer Training</span>
                        <i class="fa-solid @(Model.CPIS323 ? "fa-check completed" : "fa-xmark not-completed")"></i>
                    </li>
                </ul>
            </div>

            <div class="form5-section">
                <h4>The Student Has Completed or Registered For The Following Courses:</h4>

                <ul class="course-list">
                    <li class="course-item">
                        <span>CPIS 380 – Introduction to E-Business Systems</span>
                        <i class="fa-solid @(Model.CPIS380 ? "fa-check completed" : "fa-xmark not-completed")"></i>
                    </li>

                    <li class="course-item">
                        <span>CPIS 357 – Software Quality &amp; Testing</span>
                        <i class="fa-solid @(Model.CPIS357 ? "fa-check completed" : "fa-xmark not-completed")"></i>
                    </li>

                    <li class="course-item">
                        <span>CPIS 342 – Data Mining &amp; Warehousing</span>
                        <i class="fa-solid @(Model.CPIS342 ? "fa-check completed" : "fa-xmark not-completed")"></i>
                    </li>
                </ul>
            </div>
        }

        <div class="eligibility-status @(Model.IsEligible ? "eligible" : "not-eligible")">
            @(Model.IsEligible
                ? "The Student Is Eligible to Register Graduation Project"
                : "The Student Is Not Eligible to Register Graduation Project")
        </div>

        @if (!Model.IsHistoryView)
        {
            <div class="form5-actions">
                <form method="post"
                      asp-controller="GraduationProjectEligibility"
                      asp-action="UpdateStatus"
                      class="inline-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="formId" value="@Model.FormId" />
                    <button type="submit"
                            name="status"
                            value="Updated"
                            formaction="@Url.Action("UpdateStatus", "GraduationProjectEligibility")"
                            class="btn-accept">
                        Save
                    </button>
                </form>

                <form method="post"
                      asp-controller="GraduationProjectEligibility"
                      asp-action="SendToAdvisingCommittee"
                      class="inline-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="formId" value="@Model.FormId" />
                    <button type="submit" class="btn-send-committee">
                        Send to Advising Committee
                    </button>
                </form>
            </div>
        }
    }
@model Acadify.Models.AdminPages.UploadAcademicCalendarModel
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/upload-academic-calendar.css" />

<div class="upload-page">
    <div class="upload-card">
        <h2>Upload <span>Academic Calendar</span></h2>

        <form id="uploadForm" asp-action="UploadAcademicCalendar" asp-controller="Admin" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="upload-box">
                <input asp-for="AcademicCalendarFile" type="file" id="academicCalendarFile" accept=".xlsx" hidden />

                <label for="academicCalendarFile" class="upload-label">
                    <div class="upload-icon">☁</div>
                    <p>drag and drop file or <span>browse</span></p>
                    <p id="fileNameText" class="file-name">No file selected</p>
                </label>
            </div>

            <p class="format-text">Supported format: Excel (.xlsx)</p>

            <button type="submit" id="uploadBtn" class="upload-btn">Upload</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model?.Message))
        {
            <div class="upload-message @(Model.IsSuccess ? "success" : "error")">
                @Model.Message
            </div>
        }
    </div>

    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-box">
            <div class="spinner"></div>
            <p>Uploading academic calendar, please wait...</p>
        </div>
    </div>
</div>

<script>
    const form = document.getElementById("uploadForm");
    const fileInput = document.getElementById("academicCalendarFile");
    const fileNameText = document.getElementById("fileNameText");
    const uploadBtn = document.getElementById("uploadBtn");
    const loadingOverlay = document.getElementById("loadingOverlay");

    fileInput.addEventListener("change", function () {
        if (fileInput.files.length > 0) {
            fileNameText.textContent = "File: " + fileInput.files[0].name;
        } else {
            fileNameText.textContent = "No file selected";
        }
    });

    form.addEventListener("submit", function (e) {
        if (fileInput.files.length === 0) {
            e.preventDefault();
            alert("Please choose an Excel (.xlsx) file first.");
            return;
        }

        const fileName = fileInput.files[0].name.toLowerCase();

        if (!fileName.endsWith(".xlsx")) {
            e.preventDefault();
            alert("Only Excel (.xlsx) files are allowed.");
            return;
        }

        loadingOverlay.classList.add("show");
        uploadBtn.disabled = true;
        uploadBtn.textContent = "Uploading...";
    });
</script>